# --- Build / runtime ---
node_modules/

# --- Local archive output (regenerated by `npm run archive`) ---
# data/: per-session task records, search index, fingerprint cache
data/*
!data/.gitkeep
!data/README.md
# journal/: one Markdown file per local date
journal/*
!journal/.gitkeep
!journal/README.md
# reports/: human + machine reports, console screenshots, log files
reports/*
!reports/.gitkeep
!reports/README.md
# dist/: local handoff ZIPs (rebuilt by `npm run package:local`)
dist/*
!dist/.gitkeep

# --- Temp staging inside output dirs (used by some writers) ---
data/.tmp/
journal/.tmp/
reports/.tmp/

# --- Always-gitignored data sub-file (fingerprint cache) ---
# Kept here separately so it can never be committed even if the data/
# whitelist above is removed by accident.
data/index.json

# --- Auto-created logs / console stdout ---
reports/auto-archive.log
reports/package-local-verify.log
reports/package-local-verify.log.err
reports/console-stdout.log
reports/console-*.png
reports/test_start.cmd
*.log
*.log.err
# Whitelist the synthetic test fixtures in test-fixtures/idea-logs/.
# Those .log files are committed so `npm run test:sources` works on
# a fresh clone without any network access.
!test-fixtures/**/*.log

# --- OS / editor scratch ---
*.tmp
.DS_Store
Thumbs.db
.vscode/
.idea/
